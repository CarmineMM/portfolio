---
import MainLayout from '@layouts/MainLayout.astro'
import '../styles/global.css'
import Resume from '@/page-sections/Resume.astro'
import About from '@/page-sections/home/About.astro'
import Experience from '@/page-sections/home/Experience.astro'
import Education from '@/page-sections/home/Education.astro'
import { __, defaultLanguage } from '@config/i18n'
import FavoriteTools from '@/page-sections/home/FavoriteTools.astro'

const lang = defaultLanguage
---

<MainLayout lang={lang} bodyClasses='tapestry-bg'>
    <main
        id='main-content'
        class='container grid grid-cols-1 gap-4 pb-12 lg:grid-cols-5'
        aria-labelledby='resume-heading'
    >
        <Resume lang={lang} />
        <div class='lg:col-span-3 lg:px-12 xl:px-24'>
            <About lang={lang} />

            <Experience lang={lang} id='experience' />

            <FavoriteTools lang={lang} id='favorite-tools' />

            <Education lang={lang} id='education' />
        </div>
    </main>
</MainLayout>

<script>
    // Detect Safari browser
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent)

    if (isSafari) {
        document.body.classList.remove('tapestry-bg')
    }
</script>
