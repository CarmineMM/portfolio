---
import type PageSections from '@/interfaces/PageSections'
import _ from 'lodash'
import { __ } from '@config/i18n'

interface Props extends PageSections {
    classList?: string
}

const { lang, classList = 'lg:pt-16' } = Astro.props as Props
const sectionTitle = __('sections.about.title', { lng: lang })

const showMoreButton = "<a href='#about-heading'>{__('show-more', { lng: lang })}</a>"
---

<section class={classList} aria-labelledby='about-heading' id='about'>
    <div class='divider pb-10 lg:hidden'>
        <h2 class='h2' id='about-heading'>{sectionTitle}</h2>
    </div>
    {
        _.map(
            __('about-paragraphs', { lng: lang, returnObjects: true }),
            (paragraph: string, index: number) => <p set:html={paragraph} />
        )
    }

    {showMoreButton}
</section>
