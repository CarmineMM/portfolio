---
import type PageSections from '@/interfaces/PageSections'
import _ from 'lodash'
import { __ } from '@config/i18n'

interface Props extends PageSections {
    classList?: string
}

const { lang, classList = 'lg:pt-16' } = Astro.props as Props
const sectionTitle = __('sections.about.title', { lng: lang })
const showMore = __('show-more', { lng: lang })
---

<section class={classList} aria-labelledby='about-heading' id='about'>
    <div class='divider pb-10 lg:hidden'>
        <h2 class='h2' id='about-heading'>{sectionTitle}</h2>
    </div>
    {
        _.map(
            _.take(__('about-paragraphs', { lng: lang, returnObjects: true }) as string[], 2),
            (paragraph: string) => <p set:html={paragraph} />
        )
    }
    <div class='collapse -mb-4'>
        <input type='checkbox' id='about-more' />
        <div class='collapse-title p-0'>{showMore}</div>
        <div class='collapse-content px-0'>
            {
                _.map(
                    _.takeRight(
                        __('about-paragraphs', { lng: lang, returnObjects: true }) as string[],
                        4
                    ),
                    (paragraph: string) => <p set:html={paragraph} />
                )
            }
        </div>
    </div>
</section>
