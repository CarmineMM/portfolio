---
import { __ } from '@config/i18n'

interface Props {
    lang?: string
}

const { lang = 'es' } = Astro.props as Props

const links = [
    {
        icon: 'github',
        href: 'https://github.com/CarmineMM',
        label: __('socials.github', { lng: lang }),
    },
    {
        icon: 'linkedin',
        href: 'https://www.linkedin.com/in/carmine-maggio-157787144/',
        label: __('socials.linkedin', { lng: lang }),
    },
    {
        icon: 'instagram',
        href: 'https://www.instagram.com/carmine_maggio/',
        label: __('socials.instagram', { lng: lang }),
    },
    {
        icon: 'mail',
        href: 'mailto:carminemaggiom@gmail.com',
        label: __('socials.email', { lng: lang }),
    },
]

const navigationLabel = __('socials.label', { lng: lang })
---

<nav class='my-3 flex justify-between gap-2' role='navigation' aria-label={navigationLabel}>
    {
        links.map((link) => (
            <a
                href={link.href}
                class='btn btn-circle btn-ghost'
                target='_blank'
                rel='noopener noreferrer'
                aria-label={link.label}
                title={link.label}
            >
                <i data-feather={link.icon} class='w-5' />
                {/* <link.icon size={20} /> */}
            </a>
        ))
    }
</nav>
