---
/**
 * @file MainNavbar.astro
 * @description Desktop navigation menu component with scroll highlighting and icon support.
 */
import { type Component } from 'astro/runtime/server/index.js'

interface Link {
    href: string
    label: string
    iconSvg: Component
}

interface Props {
    lang: string
    homeUrl: string
    label: string
    homeLabel: string
    links: Link[]
}

const { lang, homeUrl, label, homeLabel, links } = Astro.props
---

<nav
    id="main-navbar"
    class="text-secondary/70 mt-12 hidden leading-8 lg:block xl:mt-16 xl:leading-10"
    aria-label={label}
>
    <h2 class="sr-only">{label}</h2>
    <ul class="space-y-2">
        <li class="hidden">
            <a href={homeUrl} class="hover:text-secondary flex items-center gap-2 transition-colors duration-300">
                {homeLabel}
            </a>
        </li>
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        data-nav-link
                        class="group flex items-center gap-3 hover:text-secondary transition-all duration-300"
                    >
                        <span class="nav-icon opacity-50 group-hover:opacity-100 transition-opacity">
                            <link.iconSvg width="1em" height="1em" />
                        </span>
                        <span class="nav-label">{link.label}</span>
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<script>
    /**
     * @file MainNavbar.astro script
     * @description Initializes the scroll spy logic for the desktop navigation.
     */
    import { findCurrentSectionIndex } from '@helpers/navigation'

    function initMainNavbar() {
        const navbar = document.getElementById('main-navbar')
        if (!navbar) return

        const navLinks = navbar.querySelectorAll('[data-nav-link]')
        const sections = Array.from(navLinks).map(link => {
            const href = link.getAttribute('href')
            if (href && href.startsWith('#')) {
                return document.getElementById(href.substring(1)) as HTMLElement
            }
            return null
        }).filter(el => el !== null)

        /**
         * @function handleScroll
         * @description Detects the active section based on scroll position and updates the UI.
         */
        const handleScroll = () => {
            const currentSectionIndex = findCurrentSectionIndex(sections, 10)

            navLinks.forEach((link, index) => {
                if (index === currentSectionIndex) {
                    link.classList.add('active-link', 'text-secondary')
                } else {
                    link.classList.remove('active-link','text-secondary')
                }
            })
        }

        // Initialize state
        handleScroll()

        // Throttled scroll listener
        let ticking = false
        window.addEventListener('scroll', () => {
            if (!ticking) {
                window.requestAnimationFrame(() => {
                    handleScroll()
                    ticking = false
                })
                ticking = true
            }
        }, { passive: true })
    }

    // Support for Astro View Transitions and regular loads
    document.addEventListener('astro:page-load', initMainNavbar)
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMainNavbar)
    } else {
        initMainNavbar()
    }
</script>